[
  {
    "name": "/profile shows unregistered state",
    "steps": [
      {
        "send": { "text": "/profile" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Kamu belum terdaftar. Ketuk /start untuk memulai."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "profile button shows unregistered state",
    "steps": [
      {
        "send": { "callback": "menu:profile" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Kamu belum terdaftar. Ketuk /start untuk memulai."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "registration then profile shows user data",
    "steps": [
      { "send": { "text": "/start" }, "expect": [] },
      {
        "send": { "text": "/profile" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "👤 Profilmu\n\nKualitas: FLAC\nBahasa: id\nTrack diputar: 0"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "profile settings shows quality options",
    "steps": [
      { "send": { "text": "/start" }, "expect": [] },
      {
        "send": { "callback": "menu:profile" },
        "expect": []
      },
      {
        "send": { "callback": "profile:settings" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "⚙️ Pengaturan\n\nKualitas saat ini: FLAC\nBahasa: Indonesia"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "profile history shows empty state",
    "steps": [
      { "send": { "text": "/start" }, "expect": [] },
      {
        "send": { "callback": "menu:profile" },
        "expect": []
      },
      {
        "send": { "callback": "profile:history" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Belum ada riwayat putar. Mulai putar beberapa track!"
            }
          }
        ]
      }
    ]
  }
]
