[
  {
    "name": "/search prompts for a query",
    "steps": [
      {
        "send": { "text": "/search" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Ketik nama track, artis, atau album untuk mencari."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "search button opens the search prompt",
    "steps": [
      {
        "send": { "callback": "menu:search" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Ketik nama track, artis, atau album untuk mencari."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "empty search returns no results",
    "steps": [
      { "send": { "text": "/start" }, "expect": [] },
      { "send": { "callback": "menu:search" }, "expect": [] },
      {
        "send": { "text": "nonexistent track xyz" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Tidak ada track ditemukan untuk \"nonexistent track xyz\". Coba kata kunci lain."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/search with query parameter searches directly",
    "steps": [
      {
        "send": { "text": "/search rock" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Tidak ada track ditemukan untuk \"rock\". Coba kata kunci lain."
            }
          }
        ]
      }
    ]
  }
]
