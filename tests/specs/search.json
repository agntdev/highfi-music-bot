[
  {
    "name": "/search prompts for a query",
    "steps": [
      {
        "send": { "text": "/search" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Type a track name, artist, or album to search."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "search button opens the search prompt",
    "steps": [
      {
        "send": { "callback": "menu:search" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Type a track name, artist, or album to search."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "empty search returns no results",
    "steps": [
      { "send": { "text": "/start" }, "expect": [] },
      { "send": { "callback": "menu:search" }, "expect": [] },
      {
        "send": { "text": "nonexistent track xyz" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No tracks found for \"nonexistent track xyz\". Try a different search."
            }
          }
        ]
      }
    ]
  }
]
